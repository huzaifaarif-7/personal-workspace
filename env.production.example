# Set these in the Vercel dashboard (Project → Settings → Environment Variables).
# Single domain: everything lives at https://personalworkspace.vercel.app

# --- Backend (Python function) env vars ---
JWT_SECRET=generate-a-new-long-random-string
FRONTEND_URL=https://personalworkspace.vercel.app
GITHUB_CALLBACK_URL=https://personalworkspace.vercel.app/api/auth/github/callback
GOOGLE_CALLBACK_URL=https://personalworkspace.vercel.app/api/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CALENDLY_TOKEN=
SLACK_USER_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
OPENROUTER_API_KEY=
LLM_MODEL=google/gemma-4-31b-it:free

# --- Frontend (Vite build) env var ---
# Same origin, so just a relative path:
VITE_API_BASE=/api
