# .env.example — copy to .env and fill in real values.
# Never commit .env to version control (.gitignore already excludes it).
#
# ── Token encryption ────────────────────────────────────────────────────────
# Used by server/crypto.py (Fernet symmetric encryption) to encrypt OAuth
# tokens before storing them in the database.
# Generate a valid key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=REPLACE_ME_generate_with_Fernet_generate_key

# ── Session cookie signing ───────────────────────────────────────────────────
# Used by Starlette's SessionMiddleware.  Any random 32+ byte hex string works.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=REPLACE_ME_generate_with_secrets_token_hex_32

# ── GitHub OAuth ─────────────────────────────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
# Set the callback URL to the value of GITHUB_REDIRECT_URI below.
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# ── Google OAuth (Calendar + Gmail) ─────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Type: OAuth 2.0 Client ID (Web application)
# Add GOOGLE_REDIRECT_URI to the list of authorised redirect URIs.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
